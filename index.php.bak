<script>
// Wait for PDF.js to be fully available before doing anything
window.addEventListener('load', function() {

  pdfjsLib.GlobalWorkerOptions.workerSrc =
    'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.worker.min.js';

  const PDF_URL   = <?php echo json_encode($pdfUrl); ?>;
  const BACK_URL  = <?php echo json_encode($backUrl); ?>;

  const canvas    = document.getElementById('cvCanvas');
  const ctx       = canvas.getContext('2d');
  const loading   = document.getElementById('cvLoading');
  const errBox    = document.getElementById('cvError');
  const totalEl   = document.getElementById('totalPages');
  const pageInput = document.getElementById('pageInput');
  const btnPrev   = document.getElementById('btnPrev');
  const btnNext   = document.getElementById('btnNext');
  const zoomLabel = document.getElementById('zoomLabel');
  const thumbsPanel = document.getElementById('cvThumbs');
  const thumbInner  = document.getElementById('thumbInner');
  const cvScroll    = document.getElementById('cvScroll');

  let pdfDoc      = null;
  let currentPage = 1;
  let numPages    = 0;
  let scale       = 1.0;
  let rendering   = false;
  let thumbsOpen  = false;
  let renderTask  = null;

  // ── LOAD ──
  pdfjsLib.getDocument({ url: PDF_URL, withCredentials: false }).promise
    .then(function(pdf) {
      pdfDoc   = pdf;
      numPages = pdf.numPages;
      totalEl.textContent = numPages;
      pageInput.max       = numPages;
      loading.style.display = 'none';
      renderCurrentPage();
      buildThumbs();
    })
    .catch(function(err) {
      loading.style.display = 'none';
      errBox.style.display  = 'flex';
      errBox.querySelector('.cv-err-msg').textContent = err.message || 'Unknown error';
      console.error('PDF.js error:', err);
    });

  // ── RENDER CURRENT PAGE ──
  function renderCurrentPage() {
    if (!pdfDoc || rendering) return;
    rendering = true;

    // cancel previous render if still going
    if (renderTask) { renderTask.cancel(); renderTask = null; }

    pdfDoc.getPage(currentPage).then(function(page) {
      const vp = page.getViewport({ scale: scale });
      canvas.width  = vp.width;
      canvas.height = vp.height;

      renderTask = page.render({ canvasContext: ctx, viewport: vp });
      return renderTask.promise;
    })
    .then(function() {
      rendering  = false;
      renderTask = null;
      updateUI();
    })
    .catch(function(err) {
      rendering = false;
      if (err && err.name !== 'RenderingCancelledException') {
        console.error('Render error:', err);
      }
    });
  }

  function updateUI() {
    pageInput.value  = currentPage;
    btnPrev.disabled = currentPage <= 1;
    btnNext.disabled = currentPage >= numPages;
    zoomLabel.textContent = Math.round(scale * 100) + '%';
    // sync mobile bar
    var mpi = document.getElementById('mPageInput');
    var mtp = document.getElementById('mTotalPages');
    var mbp = document.getElementById('mBtnPrev');
    var mbn = document.getElementById('mBtnNext');
    if (mpi) mpi.value = currentPage;
    if (mtp) mtp.textContent = numPages;
    if (mbp) mbp.disabled = currentPage <= 1;
    if (mbn) mbn.disabled = currentPage >= numPages;
    // highlight active thumb
    thumbInner.querySelectorAll('.cv-thumb-item').forEach(function(t) {
      t.classList.toggle('active', parseInt(t.dataset.page) === currentPage);
    });
    // scroll active thumb into view
    const activeThumb = thumbInner.querySelector('.cv-thumb-item.active');
    if (activeThumb && thumbsOpen) activeThumb.scrollIntoView({ block: 'nearest' });
  }

  // ── BUILD THUMBNAILS (lazy, batch of 5) ──
  function buildThumbs() {
    thumbInner.innerHTML = '';
    for (let i = 1; i <= numPages; i++) {
      const item = document.createElement('div');
      item.className    = 'cv-thumb-item';
      item.dataset.page = i;
      const lbl = document.createElement('div');
      lbl.className   = 'cv-thumb-label';
      lbl.textContent = i;
      item.appendChild(lbl);
      item.addEventListener('click', function() {
        currentPage = parseInt(this.dataset.page);
        renderCurrentPage();
      });
      thumbInner.appendChild(item);
    }
    renderThumbBatch(1);
  }

  function renderThumbBatch(startPage) {
    const batchSize = 5;
    const end = Math.min(startPage + batchSize - 1, numPages);
    const promises = [];
    for (let i = startPage; i <= end; i++) {
      promises.push(renderThumb(i));
    }
    Promise.all(promises).then(function() {
      if (end < numPages) setTimeout(function() { renderThumbBatch(end + 1); }, 50);
    });
  }

  function renderThumb(num) {
    return pdfDoc.getPage(num).then(function(page) {
      const vp  = page.getViewport({ scale: 0.2 });
      const c   = document.createElement('canvas');
      c.width   = vp.width;
      c.height  = vp.height;
      const item = thumbInner.querySelector('.cv-thumb-item[data-page="' + num + '"]');
      if (item) item.insertBefore(c, item.firstChild);
      return page.render({ canvasContext: c.getContext('2d'), viewport: vp }).promise;
    });
  }

  // ── AUTO FIT WIDTH ──
  function fitWidth() {
    if (!pdfDoc) return;
    pdfDoc.getPage(currentPage).then(function(page) {
      const vp        = page.getViewport({ scale: 1 });
      const available = cvScroll.clientWidth - 40;
      scale = available / vp.width;
      scale = Math.max(0.3, Math.min(4.0, scale));
      renderCurrentPage();
    });
  }

  // ── NAVIGATION ──
  window.goPage = function(dir) {
    const np = currentPage + dir;
    if (np < 1 || np > numPages) return;
    currentPage = np;
    renderCurrentPage();
  };

  window.jumpPage = function(val) {
    const p = Math.max(1, Math.min(numPages, parseInt(val) || 1));
    currentPage = p;
    renderCurrentPage();
  };

  window.zoom = function(delta) {
    scale = Math.max(0.3, Math.min(4.0, scale + delta));
    renderCurrentPage();
  };

  window.fitWidth = fitWidth;

  window.toggleThumbs = function() {
    thumbsOpen = !thumbsOpen;
    thumbsPanel.classList.toggle('open', thumbsOpen);
    cvScroll.style.marginLeft = thumbsOpen ? '130px' : '0';
  };

  // ── KEYBOARD ──
  document.addEventListener('keydown', function(e) {
    if (e.target.tagName === 'INPUT') return;
    if (e.key === 'ArrowRight' || e.key === 'ArrowDown' || e.key === ' ') { e.preventDefault(); window.goPage(1); }
    if (e.key === 'ArrowLeft'  || e.key === 'ArrowUp')                    { e.preventDefault(); window.goPage(-1); }
    if (e.key === '+' || e.key === '=') window.zoom(0.2);
    if (e.key === '-')                  window.zoom(-0.2);
    if (e.key === 'f' || e.key === 'F') fitWidth();
    if (e.key === 'Escape') { window.location.href = BACK_URL; }
  });

  // ── SWIPE / TOUCH ──
  var touchStartX = 0, touchStartY = 0;
  var touchStartDist = 0;
  var swipeStartScale = 1.0;
  var isSwiping = false;

  function getTouchDist(e) {
    var dx = e.touches[0].clientX - e.touches[1].clientX;
    var dy = e.touches[0].clientY - e.touches[1].clientY;
    return Math.sqrt(dx*dx + dy*dy);
  }

  cvScroll.addEventListener('touchstart', function(e) {
    if (e.touches.length === 2) {
      touchStartDist = getTouchDist(e);
      swipeStartScale = scale;
      isSwiping = false;
    } else if (e.touches.length === 1) {
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
      isSwiping = true;
    }
  }, { passive: true });

  cvScroll.addEventListener('touchmove', function(e) {
    if (e.touches.length === 2) {
      // pinch-to-zoom
      isSwiping = false;
      var dist = getTouchDist(e);
      var newScale = swipeStartScale * (dist / touchStartDist);
      scale = Math.max(0.3, Math.min(4.0, newScale));
      zoomLabel.textContent = Math.round(scale * 100) + '%';
    }
  }, { passive: true });

  cvScroll.addEventListener('touchend', function(e) {
    if (!isSwiping || e.changedTouches.length !== 1) {
      // pinch ended — re-render at new scale
      if (e.touches.length === 0 && e.changedTouches.length === 2) {
        renderCurrentPage();
      }
      return;
    }
    var dx = e.changedTouches[0].clientX - touchStartX;
    var dy = e.changedTouches[0].clientY - touchStartY;
    var absDx = Math.abs(dx);
    var absDy = Math.abs(dy);

    // Only treat as horizontal swipe if clearly horizontal (not a scroll)
    if (absDx > 50 && absDx > absDy * 1.5) {
      e.preventDefault();
      if (dx < 0) {
        window.goPage(1);   // swipe left = next
      } else {
        window.goPage(-1);  // swipe right = prev
      }
      showSwipeHint(dx < 0 ? 'next' : 'prev');
    }
  }, { passive: false });

  // ── TAP ZONES (tap left 25% = prev, right 25% = next) ──
  cvScroll.addEventListener('click', function(e) {
    if (e.target.tagName === 'CANVAS') {
      var x = e.clientX;
      var w = window.innerWidth;
      if (x < w * 0.25) {
        window.goPage(-1);
        showSwipeHint('prev');
      } else if (x > w * 0.75) {
        window.goPage(1);
        showSwipeHint('next');
      }
    }
  });

  // ── SWIPE HINT ANIMATION ──
  function showSwipeHint(dir) {
    var hint = document.getElementById('swipeHint');
    hint.textContent = dir === 'next' ? '▶' : '◀';
    hint.style.left  = dir === 'next' ? 'auto' : '20px';
    hint.style.right = dir === 'next' ? '20px' : 'auto';
    hint.style.opacity = '1';
    hint.style.transform = 'translateY(-50%) scale(1)';
    clearTimeout(hint._t);
    hint._t = setTimeout(function() {
      hint.style.opacity = '0';
      hint.style.transform = 'translateY(-50%) scale(0.7)';
    }, 400);
  }

  // ── ORIENTATION CHANGE ──
  window.addEventListener('orientationchange', function() {
    setTimeout(fitWidth, 300);
  });
  window.addEventListener('resize', function() {
    clearTimeout(window._resizeT);
    window._resizeT = setTimeout(fitWidth, 200);
  });

  // auto fit on ready
  setTimeout(fitWidth, 100);
});
</script>

<?php else: ?>
<div style="padding:80px;text-align:center;margin-top:80px;">
  <p style="color:#e8003d;">Access denied or file not found.</p>
  <a href="index.php" style="margin-top:20px;display:inline-flex;background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.1);color:#f0f0f5;padding:10px 20px;border-radius:8px;text-decoration:none;">← Back to Library</a>
</div>
<?php endif; ?>
<?php endif; ?>

<script>
  // Sticky header
  const header = document.getElementById('mainHeader');
  window.addEventListener('scroll', () => {
    header.classList.toggle('scrolled', window.scrollY > 20);
  });

  // Live search on type (debounced)
  const searchInput = document.querySelector('input[name="q"]');
  if (searchInput) {
    let timer;
    searchInput.addEventListener('input', () => {
      clearTimeout(timer);
      timer = setTimeout(() => {
        searchInput.closest('form').submit();
      }, 500);
    });
  }

  // Card entrance animation
  const cards = document.querySelectorAll('.card');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry, i) => {
      if (entry.isIntersecting) {
        entry.target.style.animationDelay = (i % 8 * 0.04) + 's';
        entry.target.classList.add('card-visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  cards.forEach(card => observer.observe(card));
</script>

<style>
  .card {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.4s ease, transform 0.4s ease,
                box-shadow 0.25s, transform 0.25s cubic-bezier(0.25,0.46,0.45,0.94);
  }
  .card.card-visible {
    opacity: 1;
    transform: translateY(0);
  }
  .card.card-visible:hover {
    transform: scale(1.055) translateY(-4px) !important;
  }
</style>


<script>
// ── LAZY ASYNC THUMBNAIL LOADER ──
// Generates missing thumbs on-demand via thumb.php?gen=1
// Uses IntersectionObserver so only visible cards trigger generation
// Retries up to 5x with exponential backoff if thumb isn't ready yet

(function() {
  var CONCURRENCY = 4; // max parallel thumb generations
  var active = 0;
  var queue = [];

  function processQueue() {
    while (active < CONCURRENCY && queue.length > 0) {
      var job = queue.shift();
      active++;
      generateThumb(job.rel, job.el, job.attempt || 1);
    }
  }

  function generateThumb(rel, el, attempt) {
    fetch('thumb.php?gen=1&pdf=' + encodeURIComponent(rel))
      .then(function(r) { return r.json(); })
      .then(function(data) {
        active--;
        if (data.ok) {
          swapInThumb(el, data.url);
        } else if (attempt < 3) {
          // retry after delay
          setTimeout(function() {
            active++;
            generateThumb(rel, el, attempt + 1);
          }, attempt * 1500);
        }
        processQueue();
      })
      .catch(function() {
        active--;
        processQueue();
      });
  }

  function swapInThumb(el, url) {
    if (!el || !el.parentNode) return;
    var card = el.closest('.card');

    if (el.tagName === 'DIV') {
      // card-placeholder -> replace with real img
      var img = document.createElement('img');
      img.src = url;
      img.alt = el.dataset.imgAlt || '';
      img.loading = 'lazy';
      img.style.width = '100%';
      img.style.height = '100%';
      img.style.objectFit = 'cover';
      img.style.display = 'block';
      el.parentNode.insertBefore(img, el);
      el.parentNode.removeChild(el);
    } else if (el.tagName === 'IMG') {
      // lazy-thumb img -> reveal
      el.src = url;
      el.style.visibility = 'visible';
    }
  }

  // Observe cards/placeholders
  var io = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (!entry.isIntersecting) return;
      io.unobserve(entry.target);

      var el = entry.target;
      var rel = el.dataset.gen;
      if (!rel) return;

      // Already loaded?
      if (el.tagName === 'IMG' && el.src && !el.src.endsWith('/')) return;

      queue.push({ rel: rel, el: el });
      processQueue();
    });
  }, {
    rootMargin: '200px 0px', // start loading 200px before visible
    threshold: 0
  });

  // Observe all placeholders and lazy hero images
  function observeAll() {
    document.querySelectorAll('.lazy-thumb-wrap, img.lazy-thumb').forEach(function(el) {
      io.observe(el);
    });
  }

  // Run on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', observeAll);
  } else {
    observeAll();
  }

  // Pre-warm: kick off thumb generation for ALL comics in background
  // (fires after page is fully rendered so it never delays display)
  window.addEventListener('load', function() {
    setTimeout(function() {
      // collect all rels that still need thumbs (not yet in queue/generated)
      document.querySelectorAll('.lazy-thumb-wrap[data-gen]').forEach(function(el) {
        if (!el._queued) {
          el._queued = true;
          queue.push({ rel: el.dataset.gen, el: el });
        }
      });
      processQueue();
    }, 500);
  });
})();
</script>
</body>
</html>
