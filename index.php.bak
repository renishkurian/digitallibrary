      <?php if (!$search): ?>
      <span style="font-size:12px;color:var(--muted);">
        <?php echo (($page-1)*$perPage+1); ?>–<?php echo min($page*$perPage,$total); ?> of <?php echo $total; ?>
      </span>
      <?php endif; ?>
    </div>

    <?php if (empty($pageFiles)): ?>
    <div class="empty-state">
      <div class="empty-icon">📚</div>
      <div class="empty-title">No Comics Found</div>
      <p>Try a different search term or check your library path.</p>
    </div>
    <?php else: ?>
    <div class="grid">
      <?php foreach ($pageFiles as $pdf):
        $rel      = str_replace($baseDir . "/", "", $pdf);
        $name     = cleanTitle(basename($pdf));
        $link     = "index.php?view=" . urlencode($rel) . ($search ? "&q=" . urlencode($search) : "") . "&page=$page";
        $hasThumb = thumbExists($pdf);
      ?>
      <a class="card" href="<?php echo htmlspecialchars($link); ?>">
        <?php if ($hasThumb): ?>
          <img src="<?php echo htmlspecialchars(thumbUrl($pdf)); ?>"
               alt="<?php echo htmlspecialchars($name); ?>"
               loading="lazy">
        <?php else: ?>
          <div class="card-placeholder lazy-thumb-wrap"
               data-gen="<?php echo urlencode(thumbRel($pdf)); ?>"
               data-img-alt="<?php echo htmlspecialchars($name); ?>">📖</div>
        <?php endif; ?>

        <div class="card-label"><?php echo htmlspecialchars($name); ?></div>

        <div class="card-overlay">
          <div class="card-title"><?php echo htmlspecialchars($name); ?></div>
          <div class="card-actions">
            <span class="card-btn play" title="Read">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
            </span>
            <span class="card-btn info" title="Info">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/>
                <line x1="12" y1="8" x2="12.01" y2="8"/>
              </svg>
            </span>
          </div>
        </div>
      </a>
      <?php endforeach; ?>
    </div>
    <?php endif; ?>
  </div>

  <!-- PAGINATION -->
  <?php if ($totalPages > 1): ?>
  <div class="pagination">
    <?php
    $qs = $search ? "&q=" . urlencode($search) : "";

    if ($page > 1):
      echo "<a class='page-btn' href='?page=" . ($page-1) . "$qs'>
              <svg width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'>
                <polyline points='15 18 9 12 15 6'/>
              </svg>
            </a>";
    endif;

    // smart page range
    $range  = 2;
    $start2 = max(1, $page - $range);
    $end2   = min($totalPages, $page + $range);

    if ($start2 > 1) {
      echo "<a class='page-btn' href='?page=1$qs'>1</a>";
      if ($start2 > 2) echo "<span class='page-ellipsis'>…</span>";
    }

    for ($i = $start2; $i <= $end2; $i++) {
      $cls = ($i == $page) ? "page-btn active" : "page-btn";
      echo "<a class='$cls' href='?page=$i$qs'>$i</a>";
    }

    if ($end2 < $totalPages) {
      if ($end2 < $totalPages - 1) echo "<span class='page-ellipsis'>…</span>";
      echo "<a class='page-btn' href='?page={$totalPages}$qs'>{$totalPages}</a>";
    }

    if ($page < $totalPages):
      echo "<a class='page-btn' href='?page=" . ($page+1) . "$qs'>
              <svg width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'>
                <polyline points='9 18 15 12 9 6'/>
              </svg>
            </a>";
    endif;
    ?>
  </div>
  <?php endif; ?>

</main>

<?php endif; // !view ?>

<!-- PDF VIEWER -->
<?php if (isset($_GET['view'])): ?>
<?php
  $viewFile   = realpath($baseDir . "/" . $_GET['view']);
  $backPage   = isset($_GET['page'])   ? (int)$_GET['page']        : 1;
  $backSearch = isset($_GET['q'])      ? $_GET['q']                : '';
  $backUrl    = "index.php?page=$backPage" . ($backSearch ? "&q=" . urlencode($backSearch) : "");
  $viewTitle  = $viewFile ? cleanTitle(basename($viewFile)) : 'Unknown';
  $pdfUrl     = "serve.php?file=" . urlencode($_GET['view']);

  if ($viewFile && str_starts_with($viewFile, $baseDir)):
?>

