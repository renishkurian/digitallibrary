  @keyframes spin { to { transform: rotate(360deg); } }

  .cv-loading-text {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    color: #8888a0;
    letter-spacing: 1px;
  }

  /* ── THUMBNAIL STRIP ── */
  .cv-thumbs {
    position: fixed;
    left: 0;
    top: 56px;
    bottom: 0;
    width: 0;
    background: rgba(10,10,15,0.97);
    border-right: 1px solid rgba(255,255,255,0.07);
    overflow-y: auto;
    overflow-x: hidden;
    transition: width 0.3s cubic-bezier(0.4,0,0.2,1);
    z-index: 10;
  }

  .cv-thumbs.open { width: 130px; }
  .cv-thumbs::-webkit-scrollbar { width: 3px; }
  .cv-thumbs::-webkit-scrollbar-thumb { background: #e8003d; }

  .cv-thumb-inner {
    padding: 12px 8px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    width: 130px;
  }

  .cv-thumb-item {
    cursor: pointer;
    border-radius: 5px;
    overflow: hidden;
    border: 2px solid transparent;
    transition: border-color 0.15s, transform 0.15s;
    background: #1a1a26;
    line-height: 0;
  }

  .cv-thumb-item:hover { border-color: rgba(232,0,61,0.5); transform: scale(1.02); }
  .cv-thumb-item.active { border-color: #e8003d; }

  .cv-thumb-item canvas {
    width: 100% !important;
    height: auto !important;
  }

  .cv-thumb-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    color: #8888a0;
    text-align: center;
    padding: 3px 0 4px;
    background: #111118;
  }

  /* ── KEYBOARD HINT ── */
  .cv-keys {
    position: fixed;
    bottom: 20px;
    right: 20px;
    display: flex;
    gap: 8px;
    opacity: 0;
    animation: fadeKeys 4s ease 1.5s forwards;
  }

  @keyframes fadeKeys {
    0%   { opacity: 0; transform: translateY(8px); }
    20%  { opacity: 1; transform: translateY(0); }
    80%  { opacity: 1; }
    100% { opacity: 0; }
  }

  .cv-key {
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.1);
    color: #8888a0;
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    padding: 4px 8px;
    border-radius: 5px;
  }

  @keyframes tapFade {
    0%   { opacity: 1; }
    70%  { opacity: 1; }
    100% { opacity: 0; }
  }

  /* ── MOBILE BOTTOM BAR ── */
  .cv-mobile-bar {
    display: none;
    flex-shrink: 0;
    height: 56px;
    background: rgba(10,10,15,0.97);
    border-top: 1px solid rgba(255,255,255,0.07);
    align-items: center;
    justify-content: space-between;
    padding: 0 12px;
    gap: 8px;
  }

  .cv-desktop-only { display: flex; }

  /* ── MOBILE: hide top-bar center controls, show bottom bar ── */
  @media (max-width: 640px) {
    .cv-bar { padding: 0 12px; gap: 8px; }
    .cv-bar-center { display: none; }
    .cv-bar-right  { display: none; }
    .cv-title { font-size: 14px; }
    .cv-back  { padding: 6px 10px; font-size: 12px; }
    .cv-mobile-bar { display: flex; }
    .cv-desktop-only { display: none !important; }
    .cv-scroll { padding: 12px 8px 16px; }
    /* canvas touch action: pan-y allows vertical scroll, we handle horizontal */
    #cvCanvas { touch-action: pan-y; cursor: pointer; }
  }

  @media (min-width: 641px) {
    .cv-mobile-bar { display: none !important; }
    #cvCanvas { touch-action: pan-y; }
  }
</style>

