<?php
$baseDir  = "/home/nicky/docker/calibre-web/books";
$thumbDir = "/var/www/html/comics/thumbs";
$perPage  = 28;

if (!file_exists($thumbDir)) mkdir($thumbDir, 0755, true);

function scanPDF($dir) {
    $files = [];
    $items = scandir($dir);
    foreach ($items as $item) {
        if ($item == "." || $item == "..") continue;
        $path = $dir . "/" . $item;
        if (is_dir($path)) {
            $files = array_merge($files, scanPDF($path));
        } else {
            if (strtolower(pathinfo($item, PATHINFO_EXTENSION)) == "pdf") {
                $files[] = $path;
            }
        }
    }
    return $files;
}

function thumbKey($pdf) {
    // Try filename match first (bash pre-gen), fallback to md5
    global $thumbDir;
    $byName = pathinfo($pdf, PATHINFO_FILENAME);
    if (file_exists($thumbDir . "/" . $byName . ".png")) return $byName;
    $byMd5  = md5($pdf);
    if (file_exists($thumbDir . "/" . $byMd5  . ".png")) return $byMd5;
    return $byName; // neither exists — default to filename for new generation
}
function thumbExists($pdf) {
    global $thumbDir;
    $key = thumbKey($pdf);
    return file_exists($thumbDir . "/" . $key . ".png");
}
function thumbUrl($pdf) {
    return "thumbs/" . rawurlencode(thumbKey($pdf)) . ".png";
}
function thumbRel($pdf) {
    global $baseDir;
    return str_replace($baseDir . "/", "", $pdf);
}

function cleanTitle($filename) {
    $name = pathinfo($filename, PATHINFO_FILENAME);
    $name = preg_replace('/[-_]/', ' ', $name);
    $name = preg_replace('/\s+/', ' ', $name);
    return trim($name);
}

$files  = scanPDF($baseDir);
$search = $_GET['q'] ?? '';

if ($search) {
    $files = array_filter($files, function ($f) use ($search) {
        return stripos($f, $search) !== false;
    });
    $files = array_values($files);
}

$total      = count($files);
$page       = isset($_GET['page']) ? max(1, (int)$_GET['page']) : 1;
$totalPages = max(1, ceil($total / $perPage));
$start      = ($page - 1) * $perPage;
$pageFiles  = array_slice($files, $start, $perPage);

// Get featured (first file or random)
$featured     = $files[0] ?? null;
$featuredName = $featured ? cleanTitle(basename($featured)) : '';
$featuredRel  = $featured ? str_replace($baseDir . "/", "", $featured) : '';
?>
